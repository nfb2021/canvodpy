flowchart TD
    subgraph Observations["📡 Observation Files"]
        RINEX["📄 RINEX v3 OBS<br/>(.YYo, .rnx)"]
        SBF["📦 SBF Binary<br/>(.YY_, .sbf)"]
    end

    subgraph EphemSources["🛰️ Ephemeris Sources"]
        direction TB
        SP3["🏛️ Agency Final<br/>SP3 + CLK<br/><i>12-18 day latency</i><br/><i>~2-3 cm accuracy</i>"]
        SBFVIS["📡 SBF Broadcast<br/>SatVisibility block<br/><i>Immediate</i><br/><i>~1-2 m accuracy</i>"]
        NAV["📄 RINEX NAV 🚧<br/>.YYp / .YYn / .YYg<br/><i>Planned — not yet implemented</i>"]
    end

    subgraph Agency["Agency Final Pipeline"]
        DL["FTP Download<br/>COD / ESA / IGS"] --> HERMI["Hermite Interpolation<br/>Orbits → target epochs"]
        HERMI --> CLK["Clock Interpolation<br/>Piecewise linear"]
        CLK --> ZCACHE["Zarr Cache<br/>aux_{date}.zarr"]
    end

    subgraph Broadcast["Broadcast Pipeline"]
        SATVIS["SatVisibility Extract<br/>θ, φ from receiver FW"]
        KEPLER["Keplerian Propagation<br/>GPS/Galileo/BeiDou orbital elements"]
        RK4["RK4 Integration<br/>GLONASS state vectors"]
    end

    subgraph Transform["Coordinate Transform"]
        SCS["compute_spherical_coordinates()<br/>ECEF → θ, φ, r"]
        DIRECT["Direct θ, φ<br/>(already computed)"]
    end

    subgraph Output["Augmented Dataset"]
        DS["ds[theta], ds[phi], ds[r]<br/>(epoch × sid)"]
    end

    SP3 --> DL
    SBFVIS --> SATVIS
    NAV --> KEPLER
    NAV --> RK4

    ZCACHE --> SCS
    KEPLER --> SCS
    RK4 --> SCS
    SATVIS --> DIRECT

    SCS --> DS
    DIRECT --> DS

    RINEX --> DS
    SBF --> DS
    SBF -.-> SBFVIS

    style Observations fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style EphemSources fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style Agency fill:#e1f5fe,stroke:#0277bd,stroke-width:2px
    style Broadcast fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style Transform fill:#f3e5f5,stroke:#4a148c,stroke-width:2px
    style Output fill:#e0f2f1,stroke:#00695c,stroke-width:2px
    style NAV fill:#fff9c4,stroke:#f9a825,stroke-width:2px,stroke-dasharray: 5 5

graph TD
    subgraph Foundation["Foundation Layer (0 inter-package deps)"]
        Utils["canvod-utils"]
        Readers["canvod-readers"]
        Grids["canvod-grids"]
        VOD["canvod-vod"]
        NAMING["canvod-virtualiconvname"]
    end

    subgraph Consumers["Consumer Layer"]
        Aux["canvod-auxiliary"]
        Store["canvod-store"]
        StoreMeta["canvod-store-metadata"]
        Viz["canvod-viz"]
        OPS["canvod-ops"]
    end

    subgraph Orchestration["Orchestration Layer"]
        Canvodpy["canvodpy"]
    end

    Canvodpy ==> Readers
    Canvodpy ==> Aux
    Canvodpy ==> Store
    Canvodpy ==> VOD
    Canvodpy ==> Grids
    Canvodpy ==> Viz
    Canvodpy ==> OPS
    Canvodpy ==> NAMING
    Canvodpy ==> StoreMeta

    Aux -.-> Readers
    Store -.-> Grids
    StoreMeta -.-> Utils
    Viz -.-> Grids
    OPS -.-> Grids
    OPS -.-> Utils

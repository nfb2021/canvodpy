        PROC["processing.yaml"]
        SITES["sites.yaml"]
        SIDS["sids.yaml"]
    end

    subgraph LOADER["Configuration Loader"]
        DEFAULTS["Package Defaults"]
        MERGE["`**Deep Merge**
        user overrides defaults`"]
        PYDANTIC["`**Pydantic Validation**
        type safety, constraints`"]
    end

    subgraph VALIDATED["CanvodConfig"]
        PC["ProcessingConfig"]
        SC["SitesConfig"]
        SIC["SidsConfig"]
    end

    subgraph VERSIONED["Versioned Data Storage"]
        IC_WRITE["Icechunk Write"]
        SNAPSHOT["Snapshot ID"]
        BRANCH["Branch Management"]
        METADATA["Metadata Table"]
    end

    subgraph PROVENANCE["Full Provenance"]
        TRACE["`Every dataset traceable to:
        config version, RINEX hash,
        snapshot ID, timestamp`"]
    end

    PROC --> MERGE
    SITES --> MERGE
    SIDS --> MERGE
    DEFAULTS --> MERGE
    MERGE --> PYDANTIC
    PYDANTIC --> PC
    PYDANTIC --> SC
    PYDANTIC --> SIC

    PC --> IC_WRITE
    IC_WRITE --> SNAPSHOT
    SNAPSHOT --> METADATA
    BRANCH --> SNAPSHOT
    METADATA --> TRACE
    SC --> TRACE
